# Firebase Public Client Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_GHL_DEFAULT_LOCATION_ID=LOC-E360-DEFAULT

# Firebase Admin SDK (Server side)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_service_account_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key\n-----END PRIVATE KEY-----\n"

# GoHighLevel (GHL) API v2 Configuration (Server side ONLY)
GHL_AGENCY_API_KEY=your_ghl_agency_private_api_key
GHL_DEFAULT_LOCATION_ID=your_ghl_default_location_id
GHL_MAIN_PIPELINE_ID=your_ghl_pipeline_id
