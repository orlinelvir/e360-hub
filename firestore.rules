rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Función auxiliar para verificar roles
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 0. Reglas para la colección de BROKERS & E360 Hub
    match /brokers/{userId} {
      allow read, write: if isOwner(userId) || (isAuthenticated() && getRole() == 'admin');

      // Clientes y Leads scoped por Broker
      match /clients/{clientId} {
        allow read, write: if isOwner(userId) || (isAuthenticated() && getRole() == 'admin');
      }

      // Tickets de soporte scoped por Broker
      match /tickets/{ticketId} {
        allow read, write: if isOwner(userId) || (isAuthenticated() && getRole() == 'admin');
      }
    }

    // 1. Reglas para la colección de USUARIOS
    match /users/{userId} {
      // Cualquier usuario autenticado puede leer su propio perfil
      allow read: if request.auth != null && request.auth.uid == userId;
      // Solo el Admin puede ver la lista de todos los usuarios
      allow list: if request.auth != null && getRole() == 'admin';
      // Solo el Admin puede crear o borrar usuarios (o el sistema vía Admin SDK)
      allow write: if request.auth != null && getRole() == 'admin';
    }

    // 2. Reglas para LEADS (Sincronizados de GHL)
    match /leads/{leadId} {
      // Admin: Acceso total
      allow read, write: if request.auth != null && getRole() == 'admin';
      // Broker: Solo lee/edita los leads que tiene asignados
      allow read, update: if request.auth != null && (getRole() == 'broker' && resource.data.brokerId == request.auth.uid);
      // Cliente: Solo lee su propia información
      allow read: if request.auth != null && (getRole() == 'client' && resource.data.clientId == request.auth.uid);
    }

    // 3. Reglas para KPIs y MÉTRICAS
    match /kpis/{kpiId} {
      allow read: if request.auth != null && (
        getRole() == 'admin' ||
        (getRole() == 'broker' && resource.data.uid == request.auth.uid)
      );
      // Solo el Admin o procesos automáticos (Make.com) escriben KPIs
      allow write: if request.auth != null && getRole() == 'admin';
    }

    // 4. Reglas para NOTIFICACIONES
    match /notifications/{notifId} {
      // Cada usuario solo lee sus propias notificaciones
      allow read: if request.auth != null && resource.data.recipientId == request.auth.uid;
      // Solo el sistema/Admin puede crear notificaciones
      allow create: if request.auth != null && getRole() == 'admin';
      // El usuario puede marcar como leída (update)
      allow update: if request.auth != null && resource.data.recipientId == request.auth.uid;
    }
  }
}
